# ===== 資料庫路徑 =====
# 預設：專案根目錄
# Google Drive 同步（請將路徑改為你的 Google Drive 資料夾）：
# DB_PATH=/Users/你的帳號/Library/CloudStorage/GoogleDrive-你的信箱/My Drive/StockAA/portfolio.db
DB_PATH=./portfolio.db

# ===== API 設定 =====
# 手續費折扣率（網路下單通常為 0.6 = 六折，預設 1.0 = 無折扣）
BROKERAGE_DISCOUNT=0.6

# API 請求 timeout（秒）
API_TIMEOUT=15

# 股價快取有效期（秒），300 = 5 分鐘
PRICE_CACHE_TTL=300

# ===== 顯示設定 =====
# 日誌等級：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== Python 設定 =====
# 禁止產生 __pycache__ 目錄與 .pyc 檔案
PYTHONDONTWRITEBYTECODE=1
